# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=assetflow
DB_USER=root
DB_PASSWORD=your_db_password

# Server Configuration
# Avoid 5000 on macOS (AirPlay Receiver / AirTunes occupies it)
PORT=5050

# Authentication
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=1d

# Background jobs (set to "true" to enable cron jobs; leave off in tests)
ENABLE_CRON=false
